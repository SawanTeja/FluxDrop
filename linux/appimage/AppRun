#!/bin/bash
set -e

APPDIR="$(dirname "$(readlink -f "$0")")"

# ── GTK4 / GLib runtime paths ──────────────────────────────────
export GDK_PIXBUF_MODULE_FILE="${APPDIR}/usr/lib/gdk-pixbuf-2.0/2.10.0/loaders.cache"
export GI_TYPELIB_PATH="${APPDIR}/usr/lib/girepository-1.0:${GI_TYPELIB_PATH}"
export GTK_DATA_PREFIX="${APPDIR}/usr"
export GTK_THEME=Adwaita
export XDG_DATA_DIRS="${APPDIR}/usr/share:${XDG_DATA_DIRS:-/usr/share}"
export GSETTINGS_SCHEMA_DIR="${APPDIR}/usr/share/glib-2.0/schemas"
export GTK_PATH="${APPDIR}/usr/lib/gtk-4.0"
export GTK_IM_MODULE_DIR="${APPDIR}/usr/lib/gtk-4.0/4.0.0/immodules"

# ── Shared libraries ───────────────────────────────────────────
export LD_LIBRARY_PATH="${APPDIR}/usr/lib:${LD_LIBRARY_PATH}"

# ── Change to binary dir so relative paths (e.g. "assets/") work
cd "${APPDIR}/usr/bin"

# ── Launch ─────────────────────────────────────────────────────
exec "${APPDIR}/usr/bin/fluxdrop_gui" "$@"
